# ============================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================
# Este archivo es un ejemplo de las variables necesarias.
# Copia este archivo a .env y completa con tus valores reales.

# ============================================
# MONGODB
# ============================================
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ============================================
# FIREBASE ADMIN SDK
# ============================================
# Obtener estos valores desde Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id

# ⚠️ IMPORTANTE: La private key debe incluir \n para los saltos de línea
# En local: copiar directamente con \n
# En Render: copiar línea por línea (sin \n, Render maneja automático)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBAD...\n-----END PRIVATE KEY-----\n"

FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk@your-project.iam.gserviceaccount.com

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS
# ============================================
# Para desarrollo local, incluir http://localhost:4200
# Para producción, incluir tu dominio de Vercel
# Ejemplo: CORS_ORIGINS=https://tu-app.vercel.app,http://localhost:4200
CORS_ORIGINS=http://localhost:4200

# ============================================
# IMAGEKIT (Si usas para subir imágenes)
# ============================================
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
